PORT=3000
HOST=127.0.0.1

# OpenAI optional. Leave empty if the bot uses fixed rules only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Provider: twilio or meta
WHATSAPP_PROVIDER=meta

# Twilio WhatsApp Sandbox / WhatsApp Sender
# For basic webhook replies, TWILIO_ACCOUNT_SID is optional.
# TWILIO_AUTH_TOKEN is needed if you enable webhook signature validation.
TWILIO_ACCOUNT_SID=AC-your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VALIDATE_WEBHOOKS=false
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example

# WhatsApp Cloud API / Meta
WHATSAPP_VERIFY_TOKEN=choose-a-private-token
WHATSAPP_ACCESS_TOKEN=EAAG-your-meta-token
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_API_VERSION=v25.0

# Optional
BOT_LANGUAGE=es
